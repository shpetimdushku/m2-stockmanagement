# Ignore everything by default
/*

# Keep metadata/docs
!.gitignore
!README.md

# Allow app root, but ignore all its direct content first
!/app/
 /app/*

# Allow only the custom module
!/app/code/
 /app/code/*
!/app/code/Digitouch/
 /app/code/Digitouch/*
!/app/code/Digitouch/StockManagement/
!/app/code/Digitouch/StockManagement/**

# Allow only custom themes if needed
!/app/design/
 /app/design/*
!/app/design/adminhtml/
 /app/design/adminhtml/*
!/app/design/adminhtml/Magento/
!/app/design/adminhtml/Magento/**

!/app/design/frontend/
 /app/design/frontend/*
!/app/design/frontend/Magento/
!/app/design/frontend/Magento/**

# Allow app/etc, but only config.php
!/app/etc/
 /app/etc/*
!/app/etc/config.php
/app/etc/env.php

# Ignore runtime/generated/vendor
/vendor/
/generated/
/var/
/pub/static/
/pub/media/
/node_modules/

# IDE / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
.phpunit.result.cache
*.swp
*.swo
