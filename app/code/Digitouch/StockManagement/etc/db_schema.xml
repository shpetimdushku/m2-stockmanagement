<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <!-- custom table "incoming_stock" per salvare la incoming quantity per ogni prodotto. engine="innodb" è importante perché InnoDB supporta
        i transactions e il row-level locking — fondamentale per risolvere la race condition!
        -->
    <table name="incoming_stock" resource="default" engine="innodb" comment="Tabella custom per gestire la incoming_qty di ogni prodotto">
        <!-- id => Pk Autoincrement -->
        <column xsi:type="int" name="id" unsigned="true" nullable="false" identity="true" comment="Primary key"/>
        <!-- entity_id => il product ID [catalog_product_entity.entity_id] -->
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" comment="ID prodotto"/>
        <!-- incoming_qty. We use decimal not int because the quantity could be in kg (es. 2.5 kg). Default 0 = Nessuna incoming_qty. -->
        <column xsi:type="decimal" name="incoming_qty" scale="4" precision="12" nullable="false" default="0" comment="Quantità in arrivo"/>
           <!-- Timestamp dell'ultimo update.
            ON_UPDATE = true significa che MySQL update -->
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Quando è stato fatto l'ultimo update"/>

        <!-- Pk La primary key -->
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>

        <!-- UNIQUE su entity_id — un solo record per prodotto, no duplicates.
            Questo e il fix della race condition:
            invece di leggere il valore e riscriverlo (che e un bug e errore),
            usiamo INSERT ... ON DUPLICATE KEY UPDATE incoming_qty = incoming_qty + X
            e lasciamo fare tutto a MySQL atomically [with no pause, single operation].
        -->
        <constraint xsi:type="unique" referenceId="DIGITOUCH_INCOMING_STOCK_ENTITY_ID_UNQ">
            <column name="entity_id"/>
        </constraint>


        <!-- Fk in catalog_product_entity.
            Se un prodotto si fa deleted, anche il suo incoming_qty
            si fa deleted automaticamente (ON CASCADE). For cleaner DB...
        -->
        <constraint xsi:type="foreign"
                    referenceId="DIGITOUCH_INCOMING_STOCK_ENTITY_ID_FK"
                    table="incoming_stock"
                    column="entity_id"
                    referenceTable="catalog_product_entity"
                    referenceColumn="entity_id"
                    onDelete="CASCADE"/>


        <!-- Index su entity_id per le SELECT piu veloce per better performance -->
        <!-- <index referenceId="INCOMING_STOCK_ENTITY_ID_INDEX" indexType="btree">
            <column name="entity_id"/>
        </index> -->
    </table>

    <!-- Custom table to send incoming_stock_notification -->
    <table name="incoming_stock_notification" resource="default" engine="innodb" comment="Richieste notifica disponibilità prodotto">
        <column xsi:type="int" name="id" unsigned="true" nullable="false" identity="true" comment="Primary key"/>
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" comment="ID prodotto"/>
        <column xsi:type="varchar" name="email" nullable="false" length="255" comment="Email utente"/>
        <column xsi:type="smallint" name="is_notified" unsigned="true" nullable="false" default="0" comment="Notifica inviata"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Data richiesta"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>

        <constraint xsi:type="foreign"
                    referenceId="DIGITOUCH_INCOMING_STOCK_NOTIFICATION_ENTITY_ID_FK"
                    table="incoming_stock_notification"
                    column="entity_id"
                    referenceTable="catalog_product_entity"
                    referenceColumn="entity_id"
                    onDelete="CASCADE"/>

        <constraint xsi:type="unique" referenceId="DIGITOUCH_INCOMING_STOCK_NOTIFICATION_ENTITY_EMAIL_UNQ">
            <column name="entity_id"/>
            <column name="email"/>
        </constraint>
    </table>
</schema>
